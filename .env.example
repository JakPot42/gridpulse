# GridPulse environment configuration
# Copy to .env and fill in real values for live mode.

# Optional — required only for live EIA data (get free key at eia.gov/opendata)
EIA_API_KEY=your_eia_api_key_here

# Optional — required only for Claude brief generation in live mode
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to False to enable live API calls (requires keys above)
DEMO_MODE=True

# Override model used for stress briefs (default: claude-haiku-4-5-20251001)
# GRIDPULSE_MODEL=claude-haiku-4-5-20251001

# Override SQLite path (default: gridpulse.db in project directory)
# GRIDPULSE_DB=gridpulse.db
